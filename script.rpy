# Скрипт для рандома
init python:
    import random

    def generate_witness_list():
        #Выбираем 3 случайных различных из 1-5
        first_three = random.sample(range(1, 6), 3)
        #Добавляем важного (6)
        return first_three + [6]

# Скрипт для звука
init python:
    def callback_bert(event, **kwargs):
        if event == "show":
            renpy.music.set_volume(0.4, delay=0, channel="sound")
            renpy.music.play("audio/beep1.wav", channel="sound", loop=True)
        elif event == "slow_done" or event == "end":
            renpy.music.stop(channel="sound")
    def callback_ann(event, **kwargs):
        if event == "show":
            renpy.music.set_volume(0.55, delay=0, channel="sound")
            renpy.music.play("audio/beep2.mp3", channel="sound", loop=True)
        elif event == "slow_done" or event == "end":
            renpy.music.stop(channel="sound")
    def callback_omy(event, **kwargs):
        if event == "show":
            renpy.music.set_volume(0.65, delay=0, channel="sound")
            renpy.music.play("audio/beep3.wav", channel="sound", loop=True)
        elif event == "slow_done" or event == "end":
            renpy.music.stop(channel="sound")

